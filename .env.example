# LineLock — copy to .env.local (gitignored) and fill in. See STATUS.md.

# Data APIs (live-tested keys live in the repo's ../.env)
FOOTBALL_DATA_KEY=
ODDS_API_KEY=

# x402 facilitator wallet (pays gas; funded separately — 402 quote works without it)
OPS_WALLET_ADDRESS=0x95DdED219bD3d763A184eB4187056b9F238aAaA2
OPS_WALLET_PK=

# x402 receiver (address only, no key)
PAYTO_ADDRESS=0x45078eD96C2bB171009A47a57aF5C085Bf4fD0e3

# Optional overrides
# LINELOCK_NETWORK=mainnet        # or 'testnet' (eip155:1439)
# LINELOCK_PRICE_UNITS=50000      # 0.05 USDC (6dp)
# PORT=8402
# LINELOCK_API_URL=http://localhost:8402   # for the web site to fetch the live API
